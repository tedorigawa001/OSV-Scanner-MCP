{
  "name": "osv-scanner-mcp",
  "version": "0.1.2",
  "description": "MCP server that wraps Google's OSV-Scanner to scan Java projects for known vulnerabilities",
  "type": "module",
  "license": "Apache-2.0",
  "author": "tedorigawa001",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "osv",
    "osv-scanner",
    "vulnerability",
    "security",
    "maven",
    "java",
    "sca"
  ],
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tedorigawa001/OSV-Scanner-MCP.git"
  },
  "homepage": "https://github.com/tedorigawa001/OSV-Scanner-MCP#readme",
  "bugs": {
    "url": "https://github.com/tedorigawa001/OSV-Scanner-MCP/issues"
  },
  "engines": {
    "node": ">=20.19"
  },
  "bin": {
    "osv-scanner-mcp": "dist/index.js"
  },
  "scripts": {
    "prebuild": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\"",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm test"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.9",
    "typescript": "^7.0.2",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  }
}
